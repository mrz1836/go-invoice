# ================================================================================================
# 🎯 PROJECT CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for go-invoice
# Load Order: 90 (loaded after all tool defaults, overrides everything except 99-local.env)
#
# This file contains project-specific configuration that overrides defaults from earlier files:
# - Coverage provider and exclusion paths
# - Pre-commit behavior
# - Codecov integration settings
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Project Go versions (overrides 00-core.env defaults)
GO_PRIMARY_VERSION=1.25.x
GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 🪄 MAGE-X CONFIGURATION
# ================================================================================================

MAGE_X_GO_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE CONFIGURATION
# ================================================================================================

# Coverage Provider Selection (override from 10-coverage.env)
GO_COVERAGE_PROVIDER=codecov

# Coverage Exclusion Paths (aligned with codecov.yml ignore paths)
GO_COVERAGE_EXCLUDE_PATHS=test/,vendor/,testdata/,examples/,plans/,docs/,.github/,.mage-cache/,.vscode/,bin/,example/,mocks/,testing/

# Skip URL Checks in Coverage Reports (speed up deployment)
GO_COVERAGE_SKIP_URL_CHECKS=true

# ================================================================================================
# 🔗 CODECOV INTEGRATION
# ================================================================================================

# Codecov Configuration (only used when provider=codecov)
CODECOV_TOKEN_REQUIRED=true

# ================================================================================================
# 🔧 PRE-COMMIT CONFIGURATION
# ================================================================================================

# Custom Pre-Commit Configuration (only look at changed files)
GO_PRE_COMMIT_ALL_FILES=false
